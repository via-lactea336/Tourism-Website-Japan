---
import { stories } from "../data/site";
---

<section id="history" class="bg-ink py-20 sm:py-24">
  <div class="mx-auto grid max-w-7xl gap-16 px-4 sm:px-6 lg:px-8">
    {
      stories.map((story, index) => {
        const reverse = index % 2 === 1;

        return (
          <article
            id={story.slug}
            data-story
            class="relative grid items-center gap-8 lg:pr-12 lg:grid-cols-2"
          >
            <picture
              data-story-media
              class:list={["order-1 block w-full", reverse ? "lg:order-2" : "lg:order-1"]}
            >
              <source srcset={story.storyImage} type="image/webp" />

              <img
                class="aspect-4/3 w-full rounded-lg object-cover shadow-2xl shadow-black/40"
                src={story.storyFallback}
                alt={story.imageAlt}
                width="1200"
                height="900"
                loading="lazy"
              />
            </picture>

            <div
              data-story-copy
              class:list={["order-2 max-w-xl", reverse ? "lg:order-1" : "lg:order-2"]}
            >
              <p class="text-sm font-extrabold uppercase tracking-[0.3em] text-vermilion">
                {story.city}
              </p>

              <h2 class="mt-3 text-4xl font-extrabold text-white sm:text-5xl">{story.title}</h2>

              <p class="mt-5 text-base leading-8 text-white/70 sm:text-lg">{story.description}</p>

              <a
                data-story-cta
                class="mt-8 inline-flex rounded-full bg-vermilion px-5 py-3 text-sm font-extrabold text-white transition hover:-translate-y-0.5 hover:bg-orange-600 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
                href={`/destinos/${story.slug}/`}
              >
                Explore {story.city}
              </a>
            </div>
            <div class="absolute inset-y-0 right-0 hidden w-px lg:block" aria-hidden="true">
              <span
                data-story-progress
                class="block h-full w-px origin-top bg-linear-to-b from-vermilion via-vermilion to-transparent"
              />
            </div>
          </article>
        );
      })
    }
  </div>
</section>
