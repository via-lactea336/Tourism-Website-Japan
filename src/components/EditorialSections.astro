---
import { destinations } from "../data/site";

const routeVisuals = [
  {
    src: "/img/home/route/route-tokyo.webp",
    alt: "A lantern-lit Tokyo side street at night",
  },
  {
    src: "/img/home/route/route-kyoto.webp",
    alt: "A traditional pagoda at blue hour",
  },
  {
    src: "/img/home/route/route-osaka.webp",
    alt: "An Osaka skyline at dusk with a distant castle silhouette",
  },
  {
    src: "/img/home/route/route-nara.webp",
    alt: "A quiet historic wooden lane in Nara at dusk",
  },
];
const route = destinations.map((destination, index) => ({
  ...destination,
  image: routeVisuals[index].src,
  imageAlt: routeVisuals[index].alt,
}));
const culturalNotes = [
  {
    title: "Food as a way into place",
    place: "Osaka",
    text: "Begin with the city’s food culture, then let a neighborhood walk set the rhythm for the rest of the day.",
    image: "/img/osaka-tales.webp",
    alt: "Osaka city lights",
  },
  {
    title: "Ritual, craft and quiet streets",
    place: "Kyoto",
    text: "Combine a cultural site with time to notice the smaller details that give a district its character.",
    image: "/img/kyoto-tales.webp",
    alt: "A traditional Kyoto street",
  },
];
const seasons = [
  {
    name: "Spring",
    note: "A season of changing landscapes and seasonal events.",
    related: "Nara and Kyoto",
    image: "/img/home/seasons/season-spring.webp",
    alt: "Pale spring blossoms beside a quiet Japanese canal",
  },
  {
    name: "Summer",
    note: "Plan around local conditions and official event guidance.",
    related: "Tokyo and Osaka",
    image: "/img/home/seasons/season-summer.webp",
    alt: "A lantern-lit Japanese summer evening street",
  },
  {
    name: "Autumn",
    note: "A time to slow down in gardens, parks and historic districts.",
    related: "Kyoto and Nara",
    image: "/img/home/seasons/season-autumn.webp",
    alt: "A Japanese garden path with autumn leaves",
  },
  {
    name: "Winter",
    note: "Build a route with current weather and opening information in mind.",
    related: "Tokyo and Osaka",
    image: "/img/home/seasons/season-winter.webp",
    alt: "A snow-dusted traditional street at blue hour",
  },
];
---

<section data-route-section class="bg-ink px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-wrap items-end justify-between gap-6 border-b border-white/15 pb-8">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[.32em] text-vermilion">
          Suggested route
        </p><h2 class="mt-3 text-5xl font-extrabold sm:text-7xl">Follow the line.</h2>
      </div><p class="max-w-sm leading-7 text-white/65">
        A suggested order for linking the destinations already featured in this guide. Confirm
        current travel details before departure.
      </p>
    </div><div class="relative mt-12">
      <div
        data-route-line
        class="absolute left-0 top-7 hidden h-px w-full origin-left bg-vermilion md:block"
        aria-hidden="true"
      >
      </div>
      <ol class="grid gap-5 md:grid-cols-4">
        {
          route.map((destination, index) => (
            <li data-route-stop class="relative">
              <>
                <span class="grid size-14 place-items-center rounded-full border border-white/30 bg-ink text-sm font-extrabold text-white">
                  0{index + 1}
                </span>
                <img
                  src={destination.image}
                  alt={destination.imageAlt}
                  width="320"
                  height="320"
                  loading="lazy"
                  class="mt-6 aspect-[4/3] w-full object-cover opacity-85"
                />
                <p class="mt-4 text-sm uppercase tracking-[.2em] text-white/55">
                  {destination.prefecture}
                </p>
                <a
                  href={`/destinos/${destination.slug}/`}
                  class="mt-1 inline-block text-2xl font-extrabold hover:text-vermilion"
                >
                  {destination.city}
                </a>
              </>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
<section class="bg-paper px-4 py-24 text-ink sm:px-6 sm:py-32 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <p class="text-sm font-extrabold uppercase tracking-[.32em] text-vermilion">
      Food & culture
    </p><div class="mt-10 grid gap-16">
      {
        culturalNotes.map((note, index) => (
          <article
            data-culture-note
            class:list={[
              "grid items-center gap-8 lg:grid-cols-2 lg:gap-16",
              index ? "lg:[&>*:first-child]:order-2" : "",
            ]}
          >
            <>
              <div class="overflow-hidden">
                <img
                  data-culture-image
                  src={note.image}
                  alt={note.alt}
                  width="1200"
                  height="900"
                  loading="lazy"
                  class="aspect-[4/3] w-full object-cover"
                />
              </div>
              <div class="max-w-xl">
                <>
                  <p class="font-display text-6xl text-vermilion">0{index + 1}</p>
                  <p class="mt-4 text-sm font-bold uppercase tracking-[.24em] text-vermilion">
                    {note.place}
                  </p>
                  <h2 class="mt-3 text-4xl font-extrabold sm:text-5xl">{note.title}</h2>
                  <p class="mt-5 text-lg leading-8 text-ink/70">{note.text}</p>
                  <a
                    class="mt-7 inline-flex border-b-2 border-vermilion pb-2 text-sm font-bold"
                    href="/destinos/"
                  >
                    Find a destination <span class="ml-2">→</span>
                  </a>
                </>
              </div>
            </>
          </article>
        ))
      }
    </div>
  </div>
</section>
<section data-seasons-section class="bg-indigo-night px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-xl">
      <p class="text-sm font-extrabold uppercase tracking-[.32em] text-vermilion">Seasons</p><h2
        class="mt-3 text-5xl font-extrabold sm:text-7xl"
      >
        Japan, in four moods.
      </h2>
    </div><div class="mt-12 grid gap-3 md:grid-cols-4">
      {
        seasons.map((season, index) => (
          <article
            data-season-panel
            class="group relative isolate min-h-100 overflow-hidden border border-white/15 p-6"
          >
            <>
              <img
                src={season.image}
                alt={season.alt}
                width="1200"
                height="900"
                loading="lazy"
                class="absolute inset-0 -z-20 h-full w-full object-cover opacity-45 transition duration-500 group-hover:scale-110 group-hover:opacity-65"
              />
              <div class="absolute inset-0 -z-10 bg-black/45" />
              <p class="font-display text-5xl text-white/65">0{index + 1}</p>
              <div class="absolute inset-x-6 bottom-6">
                <>
                  <p class="text-sm font-bold uppercase tracking-[.2em] text-vermilion">
                    {season.related}
                  </p>
                  <h3 class="mt-2 text-4xl font-extrabold">{season.name}</h3>
                  <p class="mt-3 max-w-xs leading-7 text-white/75">{season.note}</p>
                </>
              </div>
            </>
          </article>
        ))
      }
    </div>
  </div>
</section>
<section class="bg-paper px-4 py-24 text-ink sm:px-6 sm:py-32 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="border-y border-ink/20 py-5">
      <p class="text-sm font-extrabold uppercase tracking-[.32em] text-vermilion">
        Practical information
      </p>
    </div><div class="grid lg:grid-cols-[.8fr_1.2fr]">
      <div class="border-b border-ink/20 py-10 lg:border-b-0 lg:border-r lg:pr-12">
        <h2 class="text-5xl font-extrabold leading-none sm:text-7xl">Travel dossier.</h2><p
          class="mt-6 max-w-sm leading-8 text-ink/70"
        >
          A concise reminder to keep your route flexible and your plans current.
        </p>
      </div><dl class="divide-y divide-ink/20 lg:pl-12">
        <div class="grid gap-2 py-7 sm:grid-cols-[10rem_1fr]">
          <dt class="text-xs font-bold uppercase tracking-[.2em] text-vermilion">
            Before departure
          </dt><dd class="leading-7">
            Use the official destination sources on each page to confirm operating details and local
            conditions.
          </dd>
        </div><div class="grid gap-2 py-7 sm:grid-cols-[10rem_1fr]">
          <dt class="text-xs font-bold uppercase tracking-[.2em] text-vermilion">
            On the route
          </dt><dd class="leading-7">
            Group nearby places and leave room for walking, station transfers and unexpected
            discoveries.
          </dd>
        </div><div class="grid gap-2 py-7 sm:grid-cols-[10rem_1fr]">
          <dt class="text-xs font-bold uppercase tracking-[.2em] text-vermilion">
            Respectful travel
          </dt><dd class="leading-7">
            Follow venue guidance and local etiquette, especially at cultural and natural sites.
          </dd>
        </div>
      </dl>
    </div>
  </div>
</section>
<section data-final-cta class="relative isolate overflow-hidden bg-ink px-4 py-32 sm:px-6 lg:px-8">
  <img
    data-final-image
    src="/img/home/cta/cta-japan-final.webp"
    alt="A Japanese temple courtyard at blue hour with warm lantern light"
    width="1536"
    height="1024"
    loading="lazy"
    class="absolute inset-0 -z-20 h-full w-full object-cover opacity-60"
  /><div class="absolute inset-0 -z-10 bg-black/55"></div><div class="mx-auto max-w-7xl">
    <p class="text-sm font-extrabold uppercase tracking-[.32em] text-vermilion">
      Your next chapter
    </p><h2 class="mt-5 max-w-4xl font-display text-7xl uppercase leading-[.85] sm:text-9xl">
      Make space for Japan.
    </h2><p class="mt-8 max-w-xl text-lg leading-8 text-white/80">
      Start with a place, follow your curiosity, and keep the official guides close as you plan.
    </p><a
      href="/destinos/"
      class="mt-9 inline-flex rounded-full bg-vermilion px-7 py-4 text-sm font-extrabold uppercase text-white transition hover:bg-orange-700"
      >Explore destinations</a
    >
  </div>
</section>
