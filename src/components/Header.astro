---
import { navItems } from "../data/site";
const pathname = Astro.url.pathname;
---

<header class="absolute inset-x-0 top-0 z-30">
  <nav
    class="mx-auto flex w-full max-w-7xl items-center justify-between gap-4 px-4 py-5 sm:px-6 lg:px-8"
    aria-label="Primary navigation"
  >
    <a href="/" class="flex items-center gap-3 text-sm font-extrabold uppercase tracking-[0.22em]"
      ><span class="grid size-10 place-items-center rounded-full bg-white text-ink">JP</span><span
        class="hidden sm:inline">Japan Travel</span
      ></a
    ><button
      class="grid size-11 place-items-center gap-1 rounded-full border border-white/30 bg-black/25 backdrop-blur lg:hidden"
      type="button"
      data-menu-button
      aria-label="Open navigation menu"
      aria-expanded="false"
      ><span class="h-0.5 w-5 bg-white"></span><span class="h-0.5 w-5 bg-white"></span><span
        class="h-0.5 w-5 bg-white"></span></button
    ><div class="hidden items-center gap-8 lg:flex">
      {
        navItems.map((item) => (
          <a
            class:list={[
              "text-sm font-bold uppercase text-white/85 transition hover:text-white focus-visible:outline-2 focus-visible:outline-offset-4",
              pathname.startsWith("/destinos") && item.href === "/destinos/"
                ? "text-white underline underline-offset-8"
                : "",
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </div><form
      class="relative hidden items-center rounded-full border border-white/30 bg-black/20 px-4 py-2 backdrop-blur md:flex"
      data-search-form
    >
      <label class="sr-only" for="search-destination">Search destinations</label><input
        id="search-destination"
        class="w-36 bg-transparent text-sm text-white placeholder:text-white/70 focus:outline-none xl:w-52"
        type="search"
        placeholder="Search destinations"
        autocomplete="off"
      /><button class="rounded-full p-1 text-white" type="submit" aria-label="Search destinations"
        >⌕</button
      ><ul
        class="absolute right-0 top-full mt-2 hidden w-64 overflow-hidden rounded-lg border border-white/15 bg-ink shadow-2xl"
        data-search-results
      >
      </ul>
    </form><a
      class="hidden rounded-full bg-vermilion px-5 py-2.5 text-sm font-extrabold uppercase text-white shadow-[0_10px_30px_rgba(255,61,0,0.35)] transition hover:-translate-y-0.5 hover:bg-orange-600 lg:inline-flex"
      href="/destinos/">Explore</a
    >
  </nav><div
    class="mx-4 hidden rounded-lg border border-white/10 bg-ink/95 p-4 shadow-2xl backdrop-blur lg:hidden"
    data-mobile-menu
  >
    <div class="grid gap-2">
      {
        navItems.map((item) => (
          <a
            class="rounded-md px-4 py-3 text-sm font-bold uppercase text-white/85 hover:bg-white/10 focus-visible:outline-2"
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </div>
</header>
<script>
  const destinations = [
    { city: "Tokyo", slug: "tokyo" },
    { city: "Kyoto", slug: "kyoto" },
    { city: "Osaka", slug: "osaka" },
    { city: "Nara", slug: "nara" },
  ];
  const setup = () => {
    const button = document.querySelector("[data-menu-button]");
    const menu = document.querySelector("[data-mobile-menu]");
    button?.addEventListener("click", () => {
      const open = button.getAttribute("aria-expanded") === "true";
      button.setAttribute("aria-expanded", String(!open));
      button.setAttribute("aria-label", open ? "Open navigation menu" : "Close navigation menu");
      menu?.classList.toggle("hidden", open);
    });
    menu?.querySelectorAll("a").forEach((link) =>
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        button?.setAttribute("aria-expanded", "false");
      }),
    );
    const form = document.querySelector("[data-search-form]");
    const input = form?.querySelector("input");
    const results = form?.querySelector("[data-search-results]");
    const render = () => {
      if (!input || !results) return;
      const q = input.value.trim().toLowerCase();
      const matches = destinations.filter((d) => d.city.toLowerCase().includes(q));
      results.innerHTML = q
        ? matches.length
          ? matches
              .map(
                (d) =>
                  `<li><a class="block px-4 py-3 text-sm font-bold hover:bg-white/10" href="/destinos/${d.slug}/">${d.city}</a></li>`,
              )
              .join("")
          : '<li class="px-4 py-3 text-sm text-white/70">No destinations found.</li>'
        : "";
      results.classList.toggle("hidden", !q);
    };
    input?.addEventListener("input", render);
    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      const first = results?.querySelector("a");
      if (first) first.click();
    });
  };
  setup();
  document.addEventListener("astro:after-swap", setup);
</script>

<script>
  const enhanceMobileMenu = () => {
    const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");
    if (!menu || menu.dataset.enhanced) return;
    menu.dataset.enhanced = "true";
    menu.innerHTML = `
      <div class="grid gap-1" data-mobile-menu-list>
        <a data-menu-item class="rounded-md px-4 py-3 text-sm font-bold uppercase text-white/85 hover:bg-white/10 focus-visible:outline-2" href="/">Home</a>
        <div class="rounded-md" data-menu-destinations>
          <button data-destination-toggle class="flex w-full items-center justify-between rounded-md px-4 py-3 text-left text-sm font-bold uppercase text-white/85 hover:bg-white/10 focus-visible:outline-2" type="button" aria-expanded="false">Destinations <span aria-hidden="true">+</span></button>
          <div data-destination-submenu class="grid gap-1 overflow-hidden px-4 pb-2" hidden>
            <a class="block py-2 text-sm font-semibold text-white/65 hover:text-vermilion" href="/destinos/tokyo/">Tokyo</a>
            <a class="block py-2 text-sm font-semibold text-white/65 hover:text-vermilion" href="/destinos/kyoto/">Kyoto</a>
            <a class="block py-2 text-sm font-semibold text-white/65 hover:text-vermilion" href="/destinos/osaka/">Osaka</a>
            <a class="block py-2 text-sm font-semibold text-white/65 hover:text-vermilion" href="/destinos/nara/">Nara</a>
          </div>
        </div>
        <a data-menu-item class="rounded-md px-4 py-3 text-sm font-bold uppercase text-white/85 hover:bg-white/10 focus-visible:outline-2" href="/#history">Stories</a>
        <a data-menu-item class="rounded-md px-4 py-3 text-sm font-bold uppercase text-white/85 hover:bg-white/10 focus-visible:outline-2" href="/#experiences">Experiences</a>
      </div>`;

    const toggle = menu.querySelector<HTMLButtonElement>("[data-destination-toggle]");
    const submenu = menu.querySelector<HTMLElement>("[data-destination-submenu]");
    toggle?.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      toggle.querySelector("span")!.textContent = expanded ? "+" : "−";
      submenu?.toggleAttribute("hidden", expanded);
    });

    menu.addEventListener("click", (event) => {
      const link = (event.target as HTMLElement).closest<HTMLAnchorElement>("a");
      if (!link) return;
      menu.classList.add("hidden");
      const button = document.querySelector<HTMLButtonElement>("[data-menu-button]");
      button?.setAttribute("aria-expanded", "false");
      button?.setAttribute("aria-label", "Open navigation menu");
    });
  };

  enhanceMobileMenu();
  document.addEventListener("astro:page-load", enhanceMobileMenu);
</script>
