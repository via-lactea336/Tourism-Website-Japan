---
import type { GetStaticPaths } from "astro"; import BaseLayout from "../../layouts/BaseLayout.astro"; import Header from "../../components/Header.astro"; import Footer from "../../components/Footer.astro"; import { destinations } from "../../data/site";
export const getStaticPaths = (() => destinations.map((destination) => ({ params: { slug: destination.slug }, props: { destination } }))) satisfies GetStaticPaths;
const { destination } = Astro.props; const related = destinations.filter((item) => item.slug !== destination.slug).slice(0, 3);
const jsonLd = { "@context": "https://schema.org", "@type": "TouristAttraction", name: destination.city, description: destination.metaDescription, containedInPlace: { "@type": "AdministrativeArea", name: destination.prefecture }, url: Astro.url.href };
---
<BaseLayout title={destination.metaTitle} description={destination.metaDescription} jsonLd={jsonLd}><Header /><main><section class="relative isolate overflow-hidden bg-ink px-4 pb-16 pt-32 sm:px-6 lg:px-8"><img src={destination.storyImage} alt={destination.imageAlt} width="1600" height="1000" class="absolute inset-0 -z-20 h-full w-full object-cover opacity-45" fetchpriority="high" /><div class="absolute inset-0 -z-10 bg-gradient-to-r from-black via-black/75 to-black/20"></div><div class="mx-auto max-w-7xl"><nav aria-label="Breadcrumb" class="text-sm text-white/70"><a class="hover:text-white" href="/">Home</a><span aria-hidden="true"> / </span><a class="hover:text-white" href="/destinos/">Destinations</a><span aria-hidden="true"> / </span><span>{destination.city}</span></nav><div class="mt-16 max-w-3xl" data-animate="hero"><p class="text-sm font-extrabold uppercase tracking-[0.3em] text-vermilion">{destination.prefecture}</p><h1 class="mt-3 font-display text-7xl uppercase leading-none sm:text-9xl">{destination.city}</h1><p class="mt-6 text-lg leading-8 text-white/80">{destination.description}</p></div></div></section><article class="bg-paper px-4 py-16 text-ink sm:px-6 lg:px-8"><div class="mx-auto grid max-w-7xl gap-16"><section class="grid gap-8 lg:grid-cols-[1.4fr_.6fr]" data-animate="section"><div><p class="text-sm font-extrabold uppercase tracking-[.25em] text-vermilion">A closer look</p><h2 class="mt-3 text-4xl font-extrabold">Start with the character of the place.</h2><p class="mt-5 max-w-3xl text-lg leading-8 text-ink/75">{destination.introduction}</p><h2 class="mt-10 text-2xl font-extrabold">Cultural context</h2><p class="mt-3 max-w-3xl leading-8 text-ink/75">{destination.culture}</p></div><aside class="rounded-lg bg-ink p-6 text-white"><p class="text-sm font-bold uppercase tracking-[.2em] text-vermilion">At a glance</p><dl class="mt-5 grid gap-5"><div><dt class="text-sm font-bold text-white/60">Best time</dt><dd class="mt-1 leading-6">{destination.bestTime}</dd></div><div><dt class="text-sm font-bold text-white/60">Suggested pace</dt><dd class="mt-1 leading-6">{destination.visitLength}</dd></div></dl></aside></section><section data-animate="section"><p class="text-sm font-extrabold uppercase tracking-[.25em] text-vermilion">Experiences</p><div class="mt-5 grid gap-4 md:grid-cols-3">{destination.experiences.map((item) => <div class="rounded-lg border border-ink/10 bg-white p-6 font-bold shadow-sm">{item}</div>)}</div></section><section class="grid gap-8 lg:grid-cols-[.9fr_1.1fr]" data-animate="section"><div><p class="text-sm font-extrabold uppercase tracking-[.25em] text-vermilion">Practical planning</p><h2 class="mt-3 text-4xl font-extrabold">Travel with current information.</h2><p class="mt-4 leading-8 text-ink/75">Transport, access and operating conditions can change. Confirm the details that matter to your trip with the official resources below.</p></div><dl class="grid gap-4">{destination.practical.map((fact) => <div class="rounded-lg bg-white p-5 shadow-sm"><dt class="font-extrabold">{fact.label}</dt><dd class="mt-2 leading-7 text-ink/70">{fact.text}</dd></div>)}</dl></section><section data-animate="section"><h2 class="text-3xl font-extrabold">Good to know</h2><ul class="mt-5 grid gap-3 md:grid-cols-3">{destination.tips.map((tip) => <li class="rounded-lg border border-ink/10 bg-white p-5 leading-7">{tip}</li>)}</ul></section><section data-animate="section"><h2 class="text-3xl font-extrabold">Questions before you go</h2><div class="mt-5 grid gap-4 md:grid-cols-2"><details class="rounded-lg bg-white p-5 shadow-sm"><summary class="cursor-pointer font-bold">Where should I check current visitor details?</summary><p class="mt-3 leading-7 text-ink/70">Use the official destination resources listed below for current operating information, events and access notices.</p></details><details class="rounded-lg bg-white p-5 shadow-sm"><summary class="cursor-pointer font-bold">How should I plan my route?</summary><p class="mt-3 leading-7 text-ink/70">Group nearby places and check the transport provider’s current guidance before you set out.</p></details></div></section></div></article><section class="bg-ink px-4 py-16 sm:px-6 lg:px-8"><div class="mx-auto max-w-7xl"><p class="text-sm font-extrabold uppercase tracking-[.25em] text-vermilion">Continue exploring</p><div class="mt-6 grid gap-4 md:grid-cols-3">{related.map((item) => <a href={`/destinos/${item.slug}/`} class="rounded-lg border border-white/15 p-5 transition hover:bg-white/10 focus-visible:outline-2"><span class="text-sm text-white/60">{item.prefecture}</span><span class="mt-1 block text-2xl font-extrabold">{item.city}</span></a>)}</div><div class="mt-12 border-t border-white/15 pt-8"><p class="text-sm font-bold uppercase tracking-[.2em] text-white/60">Official sources</p><ul class="mt-3 flex flex-wrap gap-x-6 gap-y-2">{destination.sources.map((source) => <li><a class="text-vermilion underline underline-offset-4 hover:text-white" href={source.url} rel="noreferrer" target="_blank">{source.label}</a></li>)}</ul></div></div></section></main><Footer /></BaseLayout>
