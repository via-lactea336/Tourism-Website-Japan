---
import BaseLayout from "../../layouts/BaseLayout.astro"; import Header from "../../components/Header.astro"; import Footer from "../../components/Footer.astro"; import { destinations } from "../../data/site";
---
<BaseLayout title="Japan destinations | Japan Travel" description="Explore Tokyo, Kyoto, Osaka and Nara through an editorial Japan travel guide."><Header /><main><section class="bg-ink px-4 pb-16 pt-36 sm:px-6 lg:px-8"><div class="mx-auto max-w-7xl"><p class="text-sm font-extrabold uppercase tracking-[0.3em] text-vermilion">Destinations</p><h1 class="mt-3 max-w-3xl font-display text-6xl uppercase sm:text-8xl">Choose your pace.</h1><p class="mt-6 max-w-2xl text-lg leading-8 text-white/70">Four distinct places, each with its own rhythm. Start with what interests you and use the official resources linked on every page to confirm current details.</p></div></section><section class="bg-paper px-4 py-16 text-ink sm:px-6 lg:px-8"><div class="mx-auto grid max-w-7xl gap-6 md:grid-cols-2">{destinations.map((destination) => <article class="overflow-hidden rounded-lg bg-white shadow-sm transition hover:-translate-y-1" data-animate="section"><img src={destination.storyImage} alt={destination.imageAlt} width="1200" height="900" loading="lazy" class="aspect-[16/9] w-full object-cover" /><div class="p-6"><p class="text-sm font-bold uppercase tracking-[0.22em] text-vermilion">{destination.prefecture}</p><h2 class="mt-2 text-4xl font-extrabold">{destination.city}</h2><p class="mt-3 leading-7 text-ink/70">{destination.description}</p><a class="mt-6 inline-flex rounded-full bg-ink px-5 py-3 text-sm font-bold text-white transition hover:bg-vermilion focus-visible:outline-2 focus-visible:outline-offset-4" href={`/destinos/${destination.slug}/`}>Explore {destination.city}</a></div></article>)}</div></section></main><Footer /></BaseLayout>
