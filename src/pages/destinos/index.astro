---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DestinationMotion from "../../components/DestinationMotion.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { destinations as baseDestinations } from "../../data/site";

const internalImages = {
  tokyo: {
    src: "/img/destinations/tokyo-shinjuku.jpg",
    alt: "Night skyline of Shinjuku seen from Shibuya in Tokyo",
  },
  kyoto: {
    src: "/img/destinations/kyoto-temple.jpg",
    alt: "Historic Kyoto temple and street in blue-hour light",
  },
  osaka: { src: "/img/destinations/osaka-skyline.jpg", alt: "Osaka skyline illuminated at night" },
  nara: {
    src: "/img/destinations/nara-deer.jpg",
    alt: "Young deer standing beside stone lanterns in Nara",
  },
} as const;
const destinations = baseDestinations.map((destination) => ({
  ...destination,
  image: internalImages[destination.slug as keyof typeof internalImages].src,
  storyImage: internalImages[destination.slug as keyof typeof internalImages].src,
  imageAlt: internalImages[destination.slug as keyof typeof internalImages].alt,
}));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Japan destinations",
  itemListElement: destinations.map((destination, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: destination.city,
    url: new URL(`/destinos/${destination.slug}/`, Astro.url).href,
  })),
};
---

<BaseLayout
  title="Japan destinations | Japan Travel"
  description="Explore Tokyo, Kyoto, Osaka and Nara through an editorial Japan travel guide."
  jsonLd={jsonLd}
>
  <Header />
  <main data-destination-index>
    <section
      data-destination-hero
      class="relative isolate overflow-hidden bg-ink px-4 pb-20 pt-32 sm:px-6 lg:px-8"
    >
      <img
        data-destination-hero-media
        src="/img/destinations/index-fuji.jpg"
        alt="Mount Fuji above Kawaguchiko town"
        width="1600"
        height="1000"
        fetchpriority="high"
        class="absolute inset-0 -z-20 h-full w-full object-cover opacity-40"
      />
      <div class="absolute inset-0 -z-10 bg-linear-to-r from-black via-black/75 to-black/20"></div>
      <div class="mx-auto max-w-7xl">
        <nav aria-label="Breadcrumb" class="text-sm text-white/65">
          <a class="hover:text-white" href="/">Home</a><span aria-hidden="true"> / </span><span
            >Destinations</span
          >
        </nav><div class="mt-20 grid gap-10 lg:grid-cols-[1.2fr_.8fr]">
          <div>
            <p
              data-destination-eyebrow
              class="text-sm font-extrabold uppercase tracking-[.32em] text-vermilion"
            >
              Destination index
            </p><div class="mt-4 overflow-hidden">
              <h1
                data-destination-title
                class="font-display text-7xl uppercase leading-[.8] sm:text-9xl lg:text-[10rem]"
              >
                Choose a rhythm.
              </h1>
            </div>
          </div><div class="self-end border-l border-white/25 pl-6 sm:pl-8">
            <p data-destination-intro class="max-w-lg text-lg leading-8 text-white/80">
              Four cities, four distinct ways into Japan. Let a mood, a pace or an interest decide
              where the route begins.
            </p><p class="mt-8 text-xs font-bold uppercase tracking-[.25em] text-white/55">
              04 destinations — 01 journey
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-paper px-4 py-20 text-ink sm:px-6 sm:py-28 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-wrap items-end justify-between gap-6 border-b border-ink/20 pb-7">
          <div>
            <p class="text-sm font-extrabold uppercase tracking-[.3em] text-vermilion">
              The collection
            </p><h2 class="mt-3 text-5xl font-extrabold sm:text-7xl">Start anywhere.</h2>
          </div><p class="max-w-sm leading-7 text-ink/65">
            Each chapter offers cultural context and planning notes, with current details left to
            the official sources.
          </p>
        </div><div class="mt-12 grid gap-16">
          {
            destinations.map((destination, index) => (
              <article
                data-index-destination
                class:list={[
                  "grid items-center gap-8 lg:grid-cols-[1.15fr_.85fr] lg:gap-16",
                  index % 2 ? "lg:[&>*:first-child]:order-2" : "",
                ]}
              >
                <>
                  <a
                    href={`/destinos/${destination.slug}/`}
                    class="group relative block overflow-hidden rounded-lg bg-ink"
                    transition:name={`destination-image-${destination.slug}`}
                  >
                    <>
                      <img
                        src={destination.storyImage}
                        alt={destination.imageAlt}
                        width="1200"
                        height="900"
                        loading="lazy"
                        class="aspect-[4/3] w-full object-cover opacity-85 transition duration-700 group-hover:scale-105"
                      />
                      <span class="absolute left-5 top-5 font-display text-5xl text-white/80">
                        0{index + 1}
                      </span>
                      <span class="absolute bottom-5 right-5 border border-white/35 px-3 py-1 text-[.65rem] font-bold uppercase tracking-[.22em] text-white">
                        Open chapter
                      </span>
                    </>
                  </a>
                  <div>
                    <>
                      <p class="text-sm font-extrabold uppercase tracking-[.25em] text-vermilion">
                        {destination.prefecture}
                      </p>
                      <h3
                        transition:name={`destination-title-${destination.slug}`}
                        class="mt-3 text-5xl font-extrabold sm:text-6xl"
                      >
                        {destination.city}
                      </h3>
                      <p class="mt-3 font-display text-3xl leading-none text-ink/65">
                        {destination.tagline}
                      </p>
                      <p class="mt-6 max-w-xl text-lg leading-8 text-ink/70">
                        {destination.description}
                      </p>
                      <a
                        class="editorial-link mt-7 inline-flex items-baseline gap-3 text-sm font-bold"
                        href={`/destinos/${destination.slug}/`}
                      >
                        <>
                          <span class="editorial-link-label">
                            Explore {destination.city}
                            <span class="editorial-link-line" aria-hidden="true" />
                          </span>
                          <span aria-hidden="true">→</span>
                        </>
                      </a>
                    </>
                  </div>
                </>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-indigo-night px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[.75fr_1.25fr]">
        <div>
          <p class="text-sm font-extrabold uppercase tracking-[.3em] text-vermilion">
            A considered route
          </p><h2 class="mt-4 text-5xl font-extrabold leading-none sm:text-7xl">
            Move from pulse to pause.
          </h2>
        </div><ol class="grid gap-5 sm:grid-cols-2">
          {
            destinations.map((destination, index) => (
              <li class="border-t border-white/20 pt-4">
                <>
                  <span class="text-sm font-bold text-vermilion">0{index + 1}</span>
                  <a
                    href={`/destinos/${destination.slug}/`}
                    class="mt-2 block text-2xl font-extrabold hover:text-vermilion"
                  >
                    {destination.city}
                  </a>
                  <p class="mt-2 leading-7 text-white/65">{destination.tagline}</p>
                </>
              </li>
            ))
          }
        </ol>
      </div>
    </section>
  </main>
  <Footer />
  <DestinationMotion />
</BaseLayout>
